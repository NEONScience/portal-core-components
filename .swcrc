{
  "$schema": "https://swc.rs/schema.json",
  "jsc": {
    "target": "es2020",
    "parser": {
      "syntax": "typescript",
      "tsx": true
    },
    "transform": {
      "react": {
        "runtime": "automatic"
      }
    }
  },
  "module": {
    "type": "es6"
  },
  "exclude": [
    ".*\\.d\\.ts$",
    ".*\\/StyleGuide\\.jsx$",
    ".*\\/StyleGuide\\.tsx$"
  ]
}
