#-------------------------------------------------------------------------------
# Disable NextJS telemetry by default
# https://nextjs.org/telemetry
#-------------------------------------------------------------------------------
NEXT_TELEMETRY_DISABLED=1

NEXT_PUBLIC_NAME=$npm_package_name
NEXT_PUBLIC_VERSION=$npm_package_version

#-------------------------------------------------------------------------------
# NEON API root routes
#-------------------------------------------------------------------------------

NEXT_PUBLIC_NEON_PATH_API="/api/v0"
NEXT_PUBLIC_NEON_PATH_PUBLIC_GRAPHQL="/graphql"
NEXT_PUBLIC_NEON_PATH_LD_API="/ld"
NEXT_PUBLIC_NEON_PATH_AUTH_API="/api/auth/v0"
NEXT_PUBLIC_NEON_PATH_AUTH0_API="/auth0"
NEXT_PUBLIC_NEON_PATH_DOWNLOAD_API="/api/download/v0"

#-------------------------------------------------------------------------------
# Application routes
#-------------------------------------------------------------------------------

NEXT_PUBLIC_NEON_ROUTER_BASE=""
NEXT_PUBLIC_NEON_ROUTER_BASE_HOME="/core-components-next"

#-------------------------------------------------------------------------------
# Feature options
#-------------------------------------------------------------------------------

# Option to disable attempting to connect to the WS
# Disabled by default in development as to prevent incessant reconnect attempts
NEXT_PUBLIC_NEON_AUTH_DISABLE_WS="true"
NEXT_PUBLIC_NEON_AUTH_DISABLE_BROADCAST_CHANNEL="true"
# Option to disable session based requirements
NEXT_PUBLIC_NEON_AUTH_DISABLE_SESSION="false"
NEXT_PUBLIC_NEON_AUTH_DISABLE_AUTH0_API="true"
NEXT_PUBLIC_NEON_USE_GRAPHQL="true"
NEXT_PUBLIC_NEON_SHOW_AOP_VIEWER="true"
NEXT_PUBLIC_NEON_ENABLE_GLOBAL_SIGNIN_STATE="false"
# Option to disable fetching Drupal assets and utilize cached assets
NEXT_PUBLIC_NEON_FETCH_DRUPAL_ASSETS="true"

#-------------------------------------------------------------------------------
# Third party APIs and options
#-------------------------------------------------------------------------------

NEXT_PUBLIC_NEON_AOP_GEE_DATA_VIEWER_DESKTOP="https://neon-prod-earthengine.projects.earthengine.app/view/neon-aop-gee-data-viewer---desktop"
NEXT_PUBLIC_NEON_AOP_GEE_DATA_VIEWER_MOBILE="https://neon-prod-earthengine.projects.earthengine.app/view/aop-gee-data-viewer---mobile"
NEXT_PUBLIC_NEON_AOP_GEE_DATA_VIEWER_VIDEO="https://www.youtube.com/watch?v=61FB2v8T68s"

#-------------------------------------------------------------------------------
# Host overrides
#-------------------------------------------------------------------------------

# The API host can be overridden using NEXT_PUBLIC_NEON_API_HOST_OVERRIDE.
# Note that the override will only be applied in a dev environment.
#
# Using portal-core-components as a dependency hosted outside of data.neonscience.org:
# * Set NEXT_PUBLIC_NEON_HOST_OVERRIDE to "https://data.neonscience.org"
# Rate limiting may apply.
# See https://data.neonscience.org/data-api/rate-limiting/ for details.
#
# Preferentially override the host value with a local environment variable
# for local development purposes:
# * NEON_REACT_LOCAL_DEV_NEXT_PUBLIC_NEON_API_HOST_OVERRIDE

#NEXT_PUBLIC_NEON_API_HOST_OVERRIDE="https://data.neonscience.org"
NEXT_PUBLIC_NEON_WEB_HOST_OVERRIDE="https://www.neonscience.org"
