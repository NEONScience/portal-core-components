REACT_APP_NAME=$npm_package_name
REACT_APP_VERSION=$npm_package_version

#-------------------------------------------------------------------------------
# NEON API root routes
#-------------------------------------------------------------------------------

REACT_APP_NEON_PATH_API="/api/v0"
REACT_APP_NEON_PATH_PUBLIC_GRAPHQL="/graphql"
REACT_APP_NEON_PATH_LD_API="/ld"
REACT_APP_NEON_PATH_AUTH_API="/api/auth/v0"
REACT_APP_NEON_PATH_AUTH0_API="/auth0"
REACT_APP_NEON_PATH_DOWNLOAD_API="/api/download/v0"

#-------------------------------------------------------------------------------
# Application routes
#-------------------------------------------------------------------------------

REACT_APP_NEON_ROUTER_BASE=""
REACT_APP_NEON_ROUTER_BASE_HOME="/core-components"

#-------------------------------------------------------------------------------
# Feature options
#-------------------------------------------------------------------------------

REACT_APP_NEON_USE_GRAPHQL="true"
REACT_APP_NEON_SHOW_AOP_VIEWER="true"
REACT_APP_NEON_ENABLE_GLOBAL_SIGNIN_STATE="false"

#-------------------------------------------------------------------------------
# Third party APIs and options
#-------------------------------------------------------------------------------

REACT_APP_NEON_AOP_GEE_DATA_VIEWER_DESKTOP="https://neon-prod-earthengine.projects.earthengine.app/view/neon-aop-gee-data-viewer---desktop"
REACT_APP_NEON_AOP_GEE_DATA_VIEWER_MOBILE="https://neon-prod-earthengine.projects.earthengine.app/view/aop-gee-data-viewer---mobile"
REACT_APP_NEON_AOP_GEE_DATA_VIEWER_VIDEO="https://neoninc-my.sharepoint.com/personal/jmusinsky_battelleecology_org/_layouts/15/stream.aspx?id=%2Fpersonal%2Fjmusinsky%5Fbattelleecology%5Forg%2FDocuments%2FMicrosoft%20Teams%20Chat%20Files%2FAOP%20GEE%20Data%20Viewer%20202604%2D07%2D02%2Emp4&referrer=StreamWebApp%2EWeb&referrerScenario=AddressBarCopied%2Eview%2Ea6e7261e%2D8a2c%2D4bc3%2Db360%2Dd2a505d42a8b&ct=1775601274550&or=Teams%2DHL&ga=1&LOF=1"
